# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-64-char-string
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://avenor_user:avenor_pass@localhost:5432/avenor_db

# ── Redis (task queue) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Signal data sources ──────────────────────────────────────
APOLLO_API_KEY=
CRUNCHBASE_API_KEY=
BUILTITH_API_KEY=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
SERPAPI_KEY=

# ── HubSpot ──────────────────────────────────────────────────
HUBSPOT_APP_CLIENT_ID=
HUBSPOT_APP_CLIENT_SECRET=
HUBSPOT_WEBHOOK_SECRET=

# ── Integrations ─────────────────────────────────────────────
INSTANTLY_API_KEY=
SLACK_WEBHOOK_URL=

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
LOGFIRE_TOKEN=

# ── LLM limits ───────────────────────────────────────────────
LLM_CACHE_TTL_HOURS=24
LLM_MAX_REQUESTS_PER_WORKSPACE_PER_HOUR=10

# ── Worker schedule (cron) ───────────────────────────────────
SIGNAL_COLLECTION_CRON=0 */6 * * *
SCORE_COMPUTATION_CRON=30 */6 * * *
FEED_GENERATION_CRON=0 2 * * *
MODEL_RECALIBRATION_CRON=0 2 * * 6
