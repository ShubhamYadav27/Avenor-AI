# SENTRY_DSN=
# LOGFIRE_TOKEN=

# # ── Phase 4.2 — CRM Intelligence ─────────────────────────────
# # Fernet encryption key for HubSpot token storage (REQUIRED in production)
# # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# # HubSpot sync configuration
# HUBSPOT_HISTORICAL_DAYS=180
# HUBSPOT_SYNC_INTERVAL_MINUTES=30
# HUBSPOT_HISTORICAL_BATCH_SIZE=100

# # ── LLM limits ───────────────────────────────────────────────
# LLM_CACHE_TTL_HOURS=24
# LLM_MAX_REQUESTS_PER_WORKSPACE_PER_HOUR=10

# # ── Worker schedule (cron) ───────────────────────────────────
# SIGNAL_COLLECTION_CRON=0 */6 * * *
# SCORE_COMPUTATION_CRON=30 */6 * * *
# FEED_GENERATION_CRON=0 2 * * *
# MODEL_RECALIBRATION_CRON=0 2 * * 6


# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-64-char-string
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://avenor_user:avenor_pass@localhost:5432/avenor_db

# ── Redis (task queue) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI ───────────────────────────────────────────────────────
# Google Gemini (get a free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Signal data sources ──────────────────────────────────────
APOLLO_API_KEY=
CRUNCHBASE_API_KEY=
BUILTITH_API_KEY=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
SERPAPI_KEY=

# ── HubSpot ──────────────────────────────────────────────────
HUBSPOT_APP_CLIENT_ID=
HUBSPOT_APP_CLIENT_SECRET=
HUBSPOT_WEBHOOK_SECRET=

# ── Integrations ─────────────────────────────────────────────
INSTANTLY_API_KEY=
SLACK_WEBHOOK_URL=

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
LOGFIRE_TOKEN=

# ── Phase 4.2 — CRM Intelligence ─────────────────────────────
# Fernet encryption key for HubSpot token storage (REQUIRED in production)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# HubSpot sync configuration
HUBSPOT_HISTORICAL_DAYS=180
HUBSPOT_SYNC_INTERVAL_MINUTES=30
HUBSPOT_HISTORICAL_BATCH_SIZE=100

# ── LLM limits ───────────────────────────────────────────────
LLM_CACHE_TTL_HOURS=24
LLM_MAX_REQUESTS_PER_WORKSPACE_PER_HOUR=10

# ── Worker schedule (cron) ───────────────────────────────────
SIGNAL_COLLECTION_CRON=0 */6 * * *
SCORE_COMPUTATION_CRON=30 */6 * * *
FEED_GENERATION_CRON=0 2 * * *
MODEL_RECALIBRATION_CRON=0 2 * * 6
