# Database
DATABASE_URL=postgresql://nexus_user:nexus_pass@localhost:5432/nexus_db

# Redis (optional for MVP — set to empty string to disable)
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# Apollo.io
APOLLO_API_KEY=your_apollo_key_here

# Instantly.ai (leave blank to use mock sender)
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=

# Slack (optional — for reply notifications)
SLACK_WEBHOOK_URL=

# App
APP_ENV=development
LOG_LEVEL=INFO

# ICP config (comma-separated)
ICP_INDUSTRIES=SaaS,FinTech,B2B Software
ICP_MIN_EMPLOYEES=50
ICP_MAX_EMPLOYEES=500
ICP_LOCATIONS=United States,United Kingdom,Canada
